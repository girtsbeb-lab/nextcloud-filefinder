# Nextcloud WebDAV Configuration
NEXTCLOUD_URL=https://your-nextcloud.com/remote.php/dav/files/your_user
NEXTCLOUD_USERNAME=your_username
NEXTCLOUD_APP_PASSWORD=your_app_password

# hCaptcha Keys (https://www.hcaptcha.com/)
HCAPTCHA_SECRET=your_hcaptcha_secret
HCAPTCHA_SITEKEY=your_hcaptcha_sitekey

# App Settings
CAPTCHA_VALID_DURATION=1800
SEARCH_MIN_LENGTH=7
RESULTS_PER_PAGE=30
MAX_TRAVERSE_DEPTH=10
